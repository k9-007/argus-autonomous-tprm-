# Argus backend configuration.
# The platform runs fully offline with deterministic heuristics when keys are absent.
# Provide keys to enable live LLM reasoning and real web research.

# Reasoning provider switch: "openai" or "gemini".
ARGUS_LLM_PROVIDER=openai

# OpenAI (reasoning agents). Argus targets GPT-5.6 for the hackathon.
OPENAI_API_KEY=
ARGUS_LLM_MODEL=gpt-5.6

# Google Gemini (reasoning agents). Used when ARGUS_LLM_PROVIDER=gemini.
# See https://ai.google.dev/gemini-api/docs
GEMINI_API_KEY=
ARGUS_GEMINI_MODEL=gemini-3.5-flash

# Bright Data (Discovery/Access tools). Vendored from Studio1HQ/tprm-agent.
# Discovery uses the async Discover API (token only, no zone required).
BRIGHT_DATA_API_TOKEN=
# SERP zone is no longer used by discovery; kept for backward compatibility.
BRIGHT_DATA_SERP_ZONE=
# Web Unlocker zone is still used by the Access tool (trust-center fetching).
BRIGHT_DATA_UNLOCKER_ZONE=

# Database. Defaults to a local SQLite file; set a Postgres URL for production.
DATABASE_URL=sqlite:///./argus.db

# Base URL used when generating vendor-collaboration invite links.
ARGUS_PUBLIC_URL=http://localhost:3000

# Browser origins allowed to call this API. Use your deployed frontend URL in production.
ARGUS_CORS_ORIGINS=http://localhost:3000

# Evidence ingestion guardrails (values are bytes / count).
ARGUS_MAX_UPLOAD_BYTES=15728640
ARGUS_MAX_UPLOAD_FILES=10
